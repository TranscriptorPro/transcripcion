    style FASE1 fill:#16213e,stroke:#0f3460,color:#fff
    style FASE2 fill:#1a1a2e,stroke:#e94560,color:#fff
    style FASE3 fill:#0f3460,stroke:#533483,color:#fff
    style FASE4 fill:#1a1a2e,stroke:#e94560,color:#fff
    style GRABACION fill:#16213e,stroke:#0f3460,color:#fff
    style ARCHIVOS fill:#16213e,stroke:#0f3460,color:#fff
    style PASTE fill:#16213e,stroke:#0f3460,color:#fff
    style MODOS fill:#533483,stroke:#e94560,color:#fff
    style SEGURIDAD fill:#2c003e,stroke:#e94560,color:#fff
    style IDLE fill:#00b894,stroke:#fff,color:#000
    style TRANS10 fill:#6c5ce7,stroke:#fff,color:#fff
    style STRUCT11 fill:#e17055,stroke:#fff,color:#fff
    style FILE5 fill:#fdcb6e,stroke:#000,color:#000
    style CFG4 fill:#00b894,stroke:#fff,color:#000
