{
  "name": "transcriptor-pro",
  "version": "2.0.0",
  "description": "Transcriptor Médico Pro — Audio → Informe profesional con IA",
  "private": true,
  "scripts": {
    "deploy": "node deploy.js",
    "dev": "npx serve .",
    "build": "node build.js",
    "test": "node tests/run_tests.js",
    "audit:quick": "node scripts/audit-runner.js --profile=quick",
    "audit:full": "node scripts/audit-runner.js --profile=full",
    "qa:sandbox": "node scripts/qa-sandbox.js --page=sandbox",
    "qa:preview": "node scripts/qa-sandbox.js --page=preview",
    "qa:manual": "node scripts/qa-sandbox.js --page=manual",
    "test:e2e:admin-edit": "node tests/e2e-admin-user-edit-wizard.js",
    "test:e2e:full": "node tests/e2e-full-qa-playwright.js",
    "test:smoke:postdeploy": "node tests/smoke-postdeploy-version.js",
    "release:verify": "node scripts/release-verify.js",
    "release:verify:local": "node scripts/release-verify.js --skip-remote",
    "release:verify:remote": "node scripts/release-verify.js --skip-local --skip-build",
    "release:verify:push": "node scripts/release-verify.js --with-push"
  },
  "dependencies": {
    "playwright": "^1.58.2"
  },
  "devDependencies": {
    "terser": "^5.46.0"
  }
}
